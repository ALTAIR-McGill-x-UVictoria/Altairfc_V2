[Unit]
Description=ALTAIR V2 Flight Computer
After=network.target

[Service]
Type=notify
WorkingDirectory=/home/pi/Altairfc_V2/altairfc
ExecStart=/usr/bin/python3 main.py
Restart=on-failure
RestartSec=5
NotifyAccess=main
WatchdogSec=30
KillMode=mixed
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
